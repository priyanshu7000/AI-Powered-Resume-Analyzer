# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/resume-analyzer?retryWrites=true&w=majority

# JWT Secrets
JWT_ACCESS_SECRET=your_super_secret_access_token_key_change_this
JWT_REFRESH_SECRET=your_super_secret_refresh_token_key_change_this
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# OpenAI API
OPENAI_API_KEY=sk-your-openai-api-key-here

# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# File Upload
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=application/pdf

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100
